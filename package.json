{
  "name": "rekindle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets": "./scripts/build-icons.sh",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "npm run build && node --enable-source-maps dist/src/server.js",
    "lint": "eslint .",
    "start": "node dist/src/server.js",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.0",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
